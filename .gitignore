# Python 缓存
__pycache__/
*.pyc
*.pyo

# Python 虚拟环境
venv/
env/
.venv/

# Node.js 依赖和构建产物
frontend-vue/node_modules/
frontend-vue/dist/
frontend-vue/.vite/

# 编辑器和 IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS 系统文件
.DS_Store
Thumbs.db

# 日志
*.log

# 数据文件（如果有本地数据库）
*.db
*.sqlite

# 字体文件（版权原因，不提交到仓库）
price_maintenance_risk_analysis/fonts/*.ttf
price_maintenance_risk_analysis/fonts/*.ttc
price_maintenance_risk_analysis/fonts/*.otf
!price_maintenance_risk_analysis/fonts/.gitkeep
!price_maintenance_risk_analysis/fonts/README.md

# Jupyter Notebook 临时文件
.ipynb_checkpoints/
**/.ipynb_checkpoints/
*.ipynb_checkpoints
**/*-Copy1.ipynb
**/*-Copy*.ipynb

# 分析报告输出
price_maintenance_risk_analysis/report.txt
price_maintenance_risk_analysis/output/*.txt
price_maintenance_risk_analysis/reports/outputs/*.docx
price_maintenance_risk_analysis/reports/outputs/*.pdf
price_maintenance_risk_analysis/reports/images/*.png
price_maintenance_risk_analysis/reports/images/*.jpg
# 但保留 .gitkeep 文件
!price_maintenance_risk_analysis/reports/outputs/.gitkeep
!price_maintenance_risk_analysis/reports/images/.gitkeep
*.bak
enterprise_analysis/wanma_report/config.yaml
enterprise_analysis/wanma_report/output/*.docx
!enterprise_analysis/wanma_report/output/.gitkeep

# 行业DCF缓存数据
industry_dcf/data/*.json
